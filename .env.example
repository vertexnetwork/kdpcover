# =================================================================
# kdpcover.pro — env contract
# Mirrors vertexnetwork/hub/config/env.template.json (spec §13).
# Copy to .env.local and fill in. NEXT_PUBLIC_* values are inlined
# into the client bundle; secrets (no NEXT_PUBLIC_ prefix) stay
# server-side via Vercel encrypted env.
# =================================================================

# ----- Identity -----
NEXT_PUBLIC_SITE_NAME=kdpcover.pro
NEXT_PUBLIC_SITE_SHORT_NAME=kdpcover
NEXT_PUBLIC_SITE_DOMAIN=kdpcover.pro
NEXT_PUBLIC_SITE_URL=https://kdpcover.pro
NEXT_PUBLIC_SITE_DESCRIPTION=Pass KDP's review on the first try.
NEXT_PUBLIC_SITE_CONTACT_EMAIL=hello@kdpcover.pro

# ----- SEO verification (paste tokens from each service's console) -----
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# ----- Analytics -----
NEXT_PUBLIC_VERCEL_ANALYTICS=1
NEXT_PUBLIC_CLARITY_PROJECT_ID=
# Optional:
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_ID=

# ----- Ad provider switch (currently off) -----
NEXT_PUBLIC_AD_PROVIDER=none
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_MEDIAVINE_SITE_ID=
NEXT_PUBLIC_CARBONADS_SERVE_ID=
NEXT_PUBLIC_CARBONADS_PLACEMENT=

# ----- Affiliate (single-slot) -----
NEXT_PUBLIC_AFFILIATE_ENABLED=0
NEXT_PUBLIC_AFFILIATE_URL=
NEXT_PUBLIC_AFFILIATE_LABEL=
NEXT_PUBLIC_AFFILIATE_PROVIDER=

# ----- Email capture (Resend) -----
# Server-only secret — set in Vercel "Environment Variables" (encrypted).
RESEND_API_KEY=
# The Resend Audience UUID for kdpcover-leads (create in the Resend dashboard
# → Audiences → New Audience → name it "kdpcover-leads"; copy the UUID).
RESEND_AUDIENCE_ID=

# ----- Lemon Squeezy (template store) -----
# Single-store, single-variant per spec §10.
NEXT_PUBLIC_LEMON_SQUEEZY_STORE_ID=
NEXT_PUBLIC_LEMON_SQUEEZY_VARIANT=

# ----- Embed -----
NEXT_PUBLIC_EMBED_ENABLED=1

# ----- Chrome extension landing page -----
# Live URL of the listing once published; leaves /extension in "pending" state when blank.
NEXT_PUBLIC_CHROME_WEB_STORE_URL=
