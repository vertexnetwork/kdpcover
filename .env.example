# ----- Lemon Squeezy: template store (paid) -----
# Each value is a full hosted-checkout URL from your Lemon Squeezy variant page.
# Format: https://<your-store>.lemonsqueezy.com/buy/<variant-uuid>
# Until set, the store renders "Notify me" placeholders so SEO still ships.
NEXT_PUBLIC_LS_VARIANT_SINGLE=
NEXT_PUBLIC_LS_VARIANT_UNIVERSAL=
NEXT_PUBLIC_LS_VARIANT_MEGA=

# ----- Affiliate IDs (Recommended page) -----
# Each value is just the affiliate code/ID — the URL builder appends it.
# Leave blank to fall back to the bare URL.
NEXT_PUBLIC_AFF_CANVA=
NEXT_PUBLIC_AFF_BOOKBRUSH=
NEXT_PUBLIC_AFF_ATTICUS=
NEXT_PUBLIC_AFF_BOOKBOLT=
NEXT_PUBLIC_AFF_ROCKET=
NEXT_PUBLIC_AFF_REEDSY=
