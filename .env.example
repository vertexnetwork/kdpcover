# =================================================================
# kdpcover.pro — env contract
# Mirrors vertexnetwork/hub/config/env.template.json (spec §13).
# Copy to .env.local and fill in. NEXT_PUBLIC_* values are inlined
# into the client bundle; secrets (no NEXT_PUBLIC_ prefix) stay
# server-side via Vercel encrypted env.
# =================================================================

# ----- Identity -----
NEXT_PUBLIC_SITE_NAME=kdpcover.pro
NEXT_PUBLIC_SITE_SHORT_NAME=kdpcover
NEXT_PUBLIC_SITE_DOMAIN=kdpcover.pro
NEXT_PUBLIC_SITE_URL=https://kdpcover.pro
NEXT_PUBLIC_SITE_DESCRIPTION=Pass KDP's review on the first try.
NEXT_PUBLIC_SITE_CONTACT_EMAIL=hello@kdpcover.pro

# ----- SEO verification (paste tokens from each service's console) -----
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# ----- Analytics -----
NEXT_PUBLIC_VERCEL_ANALYTICS=1
NEXT_PUBLIC_CLARITY_PROJECT_ID=
# Google Analytics 4 measurement id (GA4 → Admin → Data streams → "G-XXXXXXXXXX").
# Consent-gated; every track() event also forwards to GA4 as a custom event.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Optional:
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_GA_ID=

# ----- Ad provider switch (currently off) -----
NEXT_PUBLIC_AD_PROVIDER=none
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_MEDIAVINE_SITE_ID=
NEXT_PUBLIC_CARBONADS_SERVE_ID=
NEXT_PUBLIC_CARBONADS_PLACEMENT=

# ----- Affiliate (single-slot) -----
NEXT_PUBLIC_AFFILIATE_ENABLED=0
NEXT_PUBLIC_AFFILIATE_URL=
NEXT_PUBLIC_AFFILIATE_LABEL=
NEXT_PUBLIC_AFFILIATE_PROVIDER=

# ----- Email capture (Resend) -----
# Server-only secret — set in Vercel "Environment Variables" (encrypted).
RESEND_API_KEY=
# The Resend Audience UUID for kdpcover-leads (create in the Resend dashboard
# → Audiences → New Audience → name it "kdpcover-leads"; copy the UUID).
RESEND_AUDIENCE_ID=

# ----- Gumroad (Cover Pass-Check store) -----
# One Gumroad product with two versions: Author ($19) and Studio ($49). The live
# permalink is baked into site-config as the default; only set this to override
# (e.g. once the get.kdpcover.pro custom domain is live). Live product URL:
#   https://thevertexnetwork.gumroad.com/l/cover-pass-check
# ENABLED=0 keeps every buy CTA in "Notify me when this drops" state.
NEXT_PUBLIC_GUMROAD_PRODUCT_URL=
# Direct link to the Studio version (for the "Upgrade to Studio" card), e.g.
#   https://thevertexnetwork.gumroad.com/l/cover-pass-check?option=<studio_id>
NEXT_PUBLIC_GUMROAD_STUDIO_URL=
NEXT_PUBLIC_GUMROAD_ENABLED=0
NEXT_PUBLIC_GUMROAD_PRICE=19
NEXT_PUBLIC_GUMROAD_STUDIO_PRICE=49

# ----- Founder cold-start offer -----
# A capped Gumroad coupon (Author tier only) shown with its LIVE remaining count.
# Create the coupon in Gumroad first: code FOUNDER, $7 off, restrict to the
# Author version, max uses 37. Then set ENABLED=1. The UI auto-hides at 0 left.
NEXT_PUBLIC_FOUNDER_ENABLED=0
NEXT_PUBLIC_FOUNDER_CODE=FOUNDER
NEXT_PUBLIC_FOUNDER_PRICE=12
NEXT_PUBLIC_FOUNDER_PERCENT=37
# Server-only seller token (Gumroad → Settings → Advanced → Applications →
# generate access token) — used read-only to fetch the coupon's remaining uses.
GUMROAD_ACCESS_TOKEN=

# ----- Cover Pass-Check (gated tool) -----
# Tool routes (/pass-check, /pass-check/unlock) 404 until this is 1. The public
# landing (/cover-pass-check) always renders so SEO compounds pre-launch.
NEXT_PUBLIC_PREFLIGHT_ENABLED=0
# Server-only secrets — set in Vercel "Environment Variables" (encrypted), NOT here.
#   GUMROAD_PRODUCT_ID      Gumroad product id (post-2023 products verify by id,
#                           not permalink). Dashboard → product → Advanced.
#   PREFLIGHT_TOKEN_SECRET  Long random string; HMAC key for the unlock cookie.
#   PREFLIGHT_USES_CAP      Max license activations before sharing is blocked (default 5).
#   GUMROAD_STUDIO_VARIANTS Comma-separated version names granting Studio (default studio,volume,batch).
GUMROAD_PRODUCT_ID=
PREFLIGHT_TOKEN_SECRET=
PREFLIGHT_USES_CAP=5
GUMROAD_STUDIO_VARIANTS=studio,volume,batch

# ----- Instant unlock (overlay + Gumroad Ping) -----
# Correlation store that auto-unlocks a buyer right after an on-site overlay
# purchase (no copy/pasting the license key). Provision a Vercel KV store
# (Storage tab) or any Upstash Redis — either var pair works. Leave blank and
# purchases still unlock via manual key entry; you just lose the auto-unlock.
# Then set Gumroad → Settings → Advanced → Ping to:
#   https://kdpcover.pro/api/gumroad/ping
KV_REST_API_URL=
KV_REST_API_TOKEN=
# (or, if using Upstash directly)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ----- Embed -----
NEXT_PUBLIC_EMBED_ENABLED=1

# ----- Chrome extension landing page -----
# Live URL of the listing once published; leaves /extension in "pending" state when blank.
NEXT_PUBLIC_CHROME_WEB_STORE_URL=
